# Secrets / local config
.env
.env.*
!.env.example
.envrc

# Python
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# uv
.uv/

# Pointer-gated large artifacts (per .env paths)
# references/* (contents ignored) but tunix is the one tracked
# exception — see docs/design-notes for the Phase 1B port rationale
references/*
!references/tunix
checkpoints/
data/
logs/
profiles/

# JAX / XLA / TPU dumps
*.profile.json.gz
xla_dumps/
tensorboard/

# Weights & Biases local state
wandb/

# HuggingFace local caches if HF_HOME points inside the repo
.cache/huggingface/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
