# opjax / Model Factory — copy to .env and fill values.
# Never commit .env. Prefer Cursor Cloud Environment secrets when available;
# this file is the local/VM fallback (gitignored via .env).

# ── Wave A (required for Model Factory cloud bootstrap) ───────────────────
# Cursor Cloud aliases also accepted by scripts/setup_cloud.sh:
#   HUGGINGFACE_TOKEN → HF_TOKEN
#   PRIMEINTELLECT_API_KEY → PRIME_API_KEY
HF_TOKEN=                         # https://huggingface.co/settings/tokens
TINKER_API_KEY=                   # https://tinker-console.thinkingmachines.ai (Inkode)
# Prime CLI: `prime login` OR API key for non-interactive cloud:
PRIME_API_KEY=                    # https://app.primeintellect.ai/dashboard/tokens

# ── Common eval / logging (reuse if present) ──────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
WANDB_API_KEY=
WANDB_PROJECT=opjax
TOGETHER_API_KEY=

# ── Modal (file auth on laptop; token pair optional in cloud) ─────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ── Hugging Face cache (cloud-friendly defaults) ──────────────────────────
HF_HOME=/tmp/huggingface
HF_HUB_CACHE=${HF_HOME}/hub
HF_DATASETS_CACHE=${HF_HOME}/datasets
HF_HUB_ENABLE_HF_TRANSFER=1

# ── Axport / Cloudflare R2 (read warehouse; bucket-scoped keys OK) ────────
# list_buckets may be AccessDenied; object ops on bucket `axport` should work.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional alternate Cloudflare token name (not required if S3 keys above are set)
R2_TOKEN_VALUE=

# ── Project paths ─────────────────────────────────────────────────────────
DATA_ROOT=./data
CHECKPOINTS_DIR=./checkpoints

# ── Model Factory (Inkling / axport / Tinker) ─────────────────────────────
FACTORY_DATA_ROOT=./data/factory
FACTORY_LOG_ROOT=./logs/factory
# DRAFT spend caps — see docs/model-factory/stage0/spend-caps.md
FACTORY_SMOKE_MAX_USD=50
FACTORY_SMOKE_MAX_STEPS=50
FACTORY_PRIVATE_MAX_USD=300
# Axport / R2 (required for Stage-4 corpus sync)
# Prefer these names (Cloud Environment / .env):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_TOKEN_VALUE=          # optional Cloudflare API token
# CLOUDFLARE_ACCOUNT_ID=   # alias of R2_ACCOUNT_ID
# AXPORT_BUCKET=axport
# Never commit real values. Rotate if pasted into chat logs.
